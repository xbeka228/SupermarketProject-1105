## A streamlined .gitignore for modern .NET projects
## including temporary files, build results, and
## files generated by popular .NET tools.

# macOS
.DS_Store

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
**/[Bb]in/
**/[Oo]bj/
[Ll]og/
[Ll]ogs/
publish/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# NuGet Packages
*.nupkg
*.snupkg

# User-specific IDE files
.vs/
.vscode/
*.user
*.suo
*.userosscache
*.sln.docstates

# dotenv environment variables file
.env

# Logs and temporary files
*.log
*.tmp
*.temp

# Others
~$*
*~
CodeCoverage/

# MSBuild Binary and Structured Log
*.binlog

# Test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.VisualState.xml
TestResult.xml
nunit-*.xml
