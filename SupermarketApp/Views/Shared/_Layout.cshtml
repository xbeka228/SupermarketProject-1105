<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Supermarket System</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom shadow-sm mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-controller="Products" asp-action="Index">SupermarketApp</a>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Products" asp-action="Index">
                                    @(Context.Request.Cookies[".AspNetCore.Culture"]?.Contains("kk") == true ? "Басты бет" : "Главная")
                                </a>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav align-items-center">
                        <li class="nav-item me-2">
                            <a class="btn btn-sm btn-outline-primary" asp-controller="Products" asp-action="SetLanguage" asp-route-culture="ru" asp-route-returnUrl="@Context.Request.Path">RU</a>
                            <a class="btn btn-sm btn-outline-primary" asp-controller="Products" asp-action="SetLanguage" asp-route-culture="kk" asp-route-returnUrl="@Context.Request.Path">KZ</a>
                        </li>
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="btn btn-danger btn-sm ms-2" asp-controller="Account" asp-action="Logout">
                                    @(Context.Request.Cookies[".AspNetCore.Culture"]?.Contains("kk") == true ? "Шығу" : "Выход")
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>