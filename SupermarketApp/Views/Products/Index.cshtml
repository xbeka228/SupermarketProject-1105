@model IEnumerable<SupermarketApp.Models.Product>
@{ 
    var isKz = Context.Request.Cookies[".AspNetCore.Culture"]?.Contains("kk") == true; 
    ViewData["Title"] = isKz ? "Тауарлар" : "Товары";
}

<div class="card shadow-sm border-0 mb-4">
    <div class="card-body d-flex justify-content-between align-items-center bg-light">
        <h2 class="m-0 text-primary">@(isKz ? "Тауарлар тізімі" : "Список товаров")</h2>
        
        <div class="d-flex gap-3">
            <form method="get" asp-action="Index" class="d-flex align-items-center gap-2">
                <label class="small fw-bold text-muted text-nowrap">@(isKz ? "Сүзгі:" : "Фильтр:")</label>
                <select name="category" class="form-select form-select-sm" onchange="this.form.submit()" style="min-width: 150px;">
                    <option value="">@(isKz ? "Барлық санаттар" : "Все категории")</option>
                    @foreach (var cat in ViewBag.Categories) 
                    { 
                        if (cat == ViewBag.SelectedCategory)
                        {
                            <option value="@cat" selected>@cat</option>
                        }
                        else
                        {
                            <option value="@cat">@cat</option>
                        }
                    }
                </select>
            </form>
            
            <a asp-action="Create" class="btn btn-success btn-sm px-3 d-flex align-items-center">
                <span class="fs-5 me-1">+</span> @(isKz ? "Қосу" : "Добавить")
            </a>
        </div>
    </div>
</div>

<div class="table-responsive shadow-sm rounded">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-dark">
            <tr>
                <th class="ps-3">@(isKz ? "Атауы" : "Название")</th>
                <th>@(isKz ? "Санаты" : "Категория")</th>
                <th>@(isKz ? "Бағасы" : "Цена")</th>
                <th>@(isKz ? "Саны" : "Кол-во")</th>
                <th class="text-center">@(isKz ? "Әрекеттер" : "Действия")</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="5" class="text-center py-4 text-muted">
                        @(isKz ? "Тауарлар табылмады" : "Товары не найдены")
                    </td>
                </tr>
            }
            @foreach (var item in Model) {
                <tr>
                    <td class="ps-3 fw-bold">@item.Name</td>
                    <td><span class="badge bg-info text-dark">@item.Category</span></td>
                    <td>@item.Price ₸</td>
                    <td>@item.Stock</td>
                    <td class="text-center">
                        <div class="btn-group">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning btn-sm">
                                ✎
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm" 
                               onclick="return confirm('@(isKz ? "Жоюды растайсыз ба?" : "Подтверждаете удаление?")')">
                                ×
                            </a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>